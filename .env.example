# Prefer Google sign-in: neo-recall-auth --google
# Env overrides are for Docker/CI only — never commit real values.
NEOSAPIEN_FIREBASE_API_KEY=
NEOSAPIEN_REFRESH_TOKEN=
# Optional: override SQLite cache path
# NEOSAPIEN_CACHE_PATH=~/.neo-recall/memories.db
# Cache TTL seconds (default 600 = 10 min)
# NEOSAPIEN_CACHE_TTL=600
